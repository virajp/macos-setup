#!/usr/bin/env zsh

##############################################################################
# macOS Setup - Update Script
##############################################################################
#
# Description:
#   Updates the Brewfile with current Homebrew installations and displays
#   a formatted diff of changes. This script helps maintain an up-to-date
#   inventory of installed packages, applications, and services.
#
# Required CLIs:
#   - brew     (Homebrew package manager)
#   - git      (Version control system)
#   - diff-so-fancy (Git diff colorizer and formatter)
#
# Usage:
#   ./update
#
# Note:
#   This script must be run from the repository root directory where the
#   Brewfile is located.
#
# Author: [Your Name]
# Created: [Date]
# Last Modified: [Date]
##############################################################################

# Update the Brewfile with current Homebrew installations
# This captures all installed formulae, casks, Mac App Store apps, and taps
echo "Updating the Brewfile ... "
brew bundle dump --all --force --describe --file=./Brewfile

# Display a formatted diff of changes to the Brewfile
# Uses diff-so-fancy for enhanced readability with syntax highlighting
echo "Printing the diff ... "
git diff --color=always | diff-so-fancy
