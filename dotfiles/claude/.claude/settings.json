{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMode": {
    "allow": [
      "Write to any file under ~/Projects/github.com/95octane",
      "Run pnpm, flutter, firebase, docker, temporal CLI commands",
      "Push/pull to 95octane GitHub repos",
      "Read and write ~/.claude directory"
    ],
    "environment": [
      "Your local dev machine with repos at ~/Projects/github.com/95octane",
      "Firebase emulator running on localhost",
      "Temporal worker in Docker",
      "Grafana in Docker",
      "iOS and Android emulators"
    ],
    "soft_deny": [
      "Do not write outside ~/Projects/github.com/95octane except ~/.claude",
      "Do not delete files without explicit instruction",
      "Do not push to production branches without confirmation"
    ]
  },
  "cleanupPeriodDays": 30,
  "effortLevel": "medium",
  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "rc@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "forceLoginMethod": "claudeai",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/enforce-pnpm.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "model": "sonnet",
  "permissions": {
    "additionalDirectories": [
      "~/Projects/github.com/95octane/apiService",
      "~/Projects/github.com/95octane/flutterApp",
      "~/Projects/github.com/95octane/astro",
      "~/.claude"
    ],
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(git *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(dart *)",
      "Bash(flutter *)",
      "Bash(firebase *)",
      "Bash(docker *)",
      "Bash(mise *)",
      "Bash(turbo *)",
      "Bash(biome *)",
      "Bash(pulumi *)",
      "Bash(doppler *)",
      "Bash(temporal *)"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(rm -rf /*)",
      "Bash(ssh *)",
      "Bash(gcloud *)"
    ]
  },
  "respectGitignore": true,
  "statusLine": {
    "command": "pnpm dlx ccstatusline@latest",
    "padding": 0,
    "type": "command"
  },
  "terminalProgressBarEnabled": true
}