{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "effortLevel": "medium",
  "forceLoginMethod": "claudeai",
  "model": "sonnet",
  "permissions": {
    "defaultMode": "default"
  },
  "respectGitignore": true,
  "statusLine": {
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "type": "command"
  },
  "terminalProgressBarEnabled": true
}