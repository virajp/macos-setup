{
  // Per-agent model settings
  "agents": {
    "explore": {
      "model": "sonnet"
    }
  },
  // Feature toggles
  "features": {
    "astTools": true,
    "autoContextInjection": true,
    "continuationEnforcement": true,
    "lspTools": true,
    "parallelExecution": true
  },
  // Magic keyword customization
  "magicKeywords": {
    "analyze": [
      "analyze",
      "investigate",
      "examine"
    ],
    "search": [
      "search",
      "find",
      "locate"
    ],
    "ultrathink": [
      "ultrathink",
      "think",
      "reason",
      "ponder"
    ],
    "ultrawork": [
      "ultrawork",
      "ulw",
      "uw"
    ]
  },
  // MCP server settings
  "mcpServers": {
    "context7": {
      "enabled": true
    },
    "exa": {
      "enabled": false
    },
    "filesystem": {
      "enabled": true
    }
  },
  // Permission settings
  "permissions": {
    "allowBash": true,
    "allowEdit": true,
    "allowWrite": true,
    "maxBackgroundTasks": 5
  },
  // Model Routing Configuration
  "routing": {
    "defaultTier": "MEDIUM",
    "enabled": true,
    // Force all agents to inherit the parent model
    // (auto-enabled when using CC Switch, Bedrock, or Vertex AI)
    "forceInherit": false
  }
}
