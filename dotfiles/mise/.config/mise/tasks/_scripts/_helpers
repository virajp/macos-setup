#!/usr/bin/env bash
#MISE hide=true
# Helper functions for mise tasks
# Source this file in other tasks using: source "${SCRIPT_DIR}/_helpers"

# Color codes
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly RED='\033[0;31m'
readonly BOLD='\033[1m'
readonly NORMAL='\033[0m'

# Emojis
readonly SUCCESS_EMOJI="✅"
readonly ERROR_EMOJI="🚫"
readonly SETTING_EMOJI="⚙️"
readonly INSTALL_EMOJI="🚀"
readonly PACKAGE_EMOJI="📦"
readonly CHECK_EMOJI="🩺"

# Print colored section header with new line
print_header() {
  local msg="$1"
  print_separator "="
  echo -e "${GREEN}${BOLD}${msg}${NORMAL}"
}

# Print colored section sub-header with new line
print_subheader() {
  local msg="$1"
  print_separator "-"
  echo -e "${GREEN}${BOLD}${msg}${NORMAL}"
}

# Print colored section header without new line
print_wait() {
  local msg="$1"
  echo -en "${YELLOW}${BOLD}${msg}${NORMAL}"
}

# Print empty line
print_newline() {
  echo ""
}

print_error() {
  local msg="$1"
  echo -e "${ERROR_EMOJI} ${RED}${BOLD}${msg}${NORMAL}"
}

print_success() {
  local msg="$1"
  echo -e "${SUCCESS_EMOJI} ${GREEN}${BOLD}${msg}${NORMAL}"
}

##
# Repeats a character string across the terminal width
# Useful for creating visual separators in terminal output
#
# @param $1 - Character or string to repeat
# @return 0 on success
# @example print_separator '='    # Creates a line of equals signs
# @example print_separator '-'    # Creates a line of dashes
# @note Fish equivalent: repchar function in repchar.fish
##
function print_separator() {
  local COLS
  COLS=$(stty size </dev/tty 2>/dev/null | awk '{print $2}')
  COLS="${COLS:-80}"
  local LENGTH=$(( COLS / ${#1} ))
  for (( i = 1; i <= LENGTH; i++ )); do printf -- "$1"; done
  echo ""
}
