{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "context7": {
      "command": [
        "pnpx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "timeout": 10000,
      "type": "local"
    },
    "mempalace": {
      "command": [
        "mempalace-mcp"
      ],
      "enabled": true,
      "timeout": 10000,
      "type": "local"
    }
  },
  "model": "opencode/kimi-k2.6",
  "permission": {
    "apply_patch": "allow",
    "bash": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "read": "allow",
    "skill": {
      "*": "allow"
    },
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "write": "allow"
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@warp-dot-dev/opencode-warp",
    [
      "@devtheops/opencode-plugin-mempalace",
      {
        "autoMine": true,
        "flushOnExit": true,
        "flushOnIdle": true,
        "injectOnCompaction": true,
        "injectWakeUp": true,
        "maxWakeUpChars": 4000,
        "threshold": 15
      }
    ]
  ],
  "server": {
    "port": 4096
  },
  "watcher": {}
}
