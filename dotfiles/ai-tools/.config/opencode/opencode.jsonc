{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "context7": {
      "command": [
        "pnpx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "timeout": 10000,
      "type": "local"
    },
    "mempalace": {
      "command": [
        "mempalace-mcp"
      ],
      "enabled": true,
      "timeout": 10000,
      "type": "local"
    }
  },
  "model": "opencode/nemotron-3-ultra-free",
  "permission": {
    "apply_patch": "allow",
    "bash": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "read": "allow",
    "skill": {
      "*": "allow"
    },
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "write": "allow"
  },
  "plugin": [
    "@warp-dot-dev/opencode-warp"
  ],
  "server": {
    "port": 4096
  },
  "watcher": {}
}
