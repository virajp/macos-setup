{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "effortLevel": "high",
  "enabledPlugins": {
    "context7@virajp-plugins": true,
    "markdown@virajp-plugins": true,
    "mempalace@virajp-plugins": true,
    "typescript-lsp@virajp-plugins": true,
    "vwf@virajp-plugins": true,
    "warp@claude-code-warp": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_INSTALL_METHOD": "other",
    "DISABLE_AUTOUPDATER": "1"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "repo": "warpdotdev/claude-code-warp",
        "source": "github"
      }
    },
    "claude-plugins-official": {
      "source": {
        "repo": "anthropics/claude-plugins-official",
        "source": "github"
      }
    },
    "virajp-plugins": {
      "source": {
        "repo": "virajp/ai-plugins",
        "source": "github"
      }
    }
  },
  "forceLoginMethod": "claudeai",
  "hooks": {},
  "includeCoAuthoredBy": true,
  "model": "sonnet[1m]",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash",
      "Skill",
      "WebFetch",
      "Agent"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(* sudo *)",
      "Bash(sudo *)",
      "Bash(* su *)",
      "Bash(su *)",
      "Bash(* ssh *)",
      "Bash(ssh *)",
      "Bash(* firebase *)",
      "Bash(firebase *)",
      "Bash(* gcloud *)",
      "Bash(gcloud *)",
      "Bash(doppler *)",
      "Bash(* doppler *)"
    ]
  },
  "respectGitignore": true,
  "skipDangerousModePermissionPrompt": true,
  "spinnerTipsEnabled": false,
  "statusLine": {
    "command": "${HOME}/.claude/scripts/statusline",
    "padding": 0,
    "refreshInterval": 4,
    "type": "command"
  },
  "subagentStatusLine": {
    "command": "${HOME}/.claude/scripts/statusline",
    "type": "command"
  },
  "terminalProgressBarEnabled": true,
  "theme": "dark"
}
