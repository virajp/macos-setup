{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "effortLevel": "medium",
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "mempalace@mempalace": true,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "vlsp-dart@virajp-plugins": true,
    "vlsp-ts-js@virajp-plugins": true,
    "vskills@virajp-plugins": true,
    "warp@claude-code-warp": false
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_INSTALL_METHOD": "other",
    "DISABLE_AUTOUPDATER": "1"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "repo": "warpdotdev/claude-code-warp",
        "source": "github"
      }
    },
    "mempalace": {
      "source": {
        "repo": "MemPalace/mempalace",
        "source": "github"
      }
    },
    "virajp-plugins": {
      "source": {
        "repo": "virajp/claude-plugins",
        "source": "github"
      }
    }
  },
  "forceLoginMethod": "claudeai",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/herdr-agent-state.sh blocked",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/plugins/marketplaces/mempalace/hooks/mempal_precompact_hook.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/hooks/npm-to-pnpm.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/herdr-agent-state.sh working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/herdr-agent-state.sh release",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/herdr-agent-state.sh idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/plugins/marketplaces/mempalace/hooks/mempal_save_hook.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/herdr-agent-state.sh idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ${HOME}/.claude/hooks/herdr-agent-state.sh working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeCoAuthoredBy": true,
  "model": "opus",
  "permissions": {
    "allow": [
      "Skill",
      "WebFetch",
      "Agent"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(ssh *)",
      "Bash(firebase *)",
      "Bash(gcloud *)",
      "Bash(doppler *)"
    ]
  },
  "respectGitignore": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 4,
    "type": "command"
  },
  "terminalProgressBarEnabled": true,
  "theme": "dark"
}
