{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "effortLevel": "medium",
  "enabledPlugins": {
    "mempalace@mempalace": true,
    "warp@claude-code-warp": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_INSTALL_METHOD": "other",
    "DISABLE_AUTOUPDATER": "1"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "repo": "warpdotdev/claude-code-warp",
        "source": "github"
      }
    },
    "mempalace": {
      "source": {
        "repo": "MemPalace/mempalace",
        "source": "github"
      }
    }
  },
  "forceLoginMethod": "claudeai",
  "hooks": {
    "PermissionRequest": [],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/plugins/marketplaces/mempalace/hooks/mempal_precompact_hook.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [],
    "SessionStart": [],
    "Stop": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/plugins/marketplaces/mempalace/hooks/mempal_save_hook.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": []
  },
  "includeCoAuthoredBy": true,
  "model": "sonnet[1m]",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash",
      "Skill",
      "WebFetch",
      "Agent"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(ssh *)",
      "Bash(firebase *)",
      "Bash(gcloud *)",
      "Bash(doppler *)"
    ]
  },
  "respectGitignore": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 4,
    "type": "command"
  },
  "terminalProgressBarEnabled": true,
  "theme": "dark"
}
