{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "warp@claude-code-warp": false
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_INSTALL_METHOD": "other",
    "DISABLE_AUTOUPDATER": "1"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "repo": "warpdotdev/claude-code-warp",
        "source": "github"
      }
    },
    "virajp-claude-plugins": {
      "source": {
        "repo": "virajp/claude-plugins",
        "source": "github"
      }
    }
  },
  "forceLoginMethod": "claudeai",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash '/Users/virajpatel/.claude/hooks/herdr-agent-state.sh' blocked",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/npm-to-pnpm.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/virajpatel/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash '/Users/virajpatel/.claude/hooks/herdr-agent-state.sh' release",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/virajpatel/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash '/Users/virajpatel/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash '/Users/virajpatel/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeCoAuthoredBy": true,
  "model": "sonnet[1m]",
  "permissions": {
    "allow": [
      "Skill",
      "WebFetch",
      "Agent"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(ssh *)",
      "Bash(firebase *)",
      "Bash(gcloud *)",
      "Bash(doppler *)"
    ]
  },
  "respectGitignore": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 4,
    "type": "command"
  },
  "terminalProgressBarEnabled": true,
  "theme": "dark"
}
