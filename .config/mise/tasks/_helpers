#!/usr/bin/env zsh
#MISE hide=true
# Helper functions for mise tasks
# Source this file in other tasks using: source "${SCRIPT_DIR}/_helpers"

# Color codes
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly RED='\033[0;31m'
readonly BOLD='\033[1m'
readonly NORMAL='\033[0m'

# Print colored section header with new line
print_header() {
  local msg="$1"
  echo -e "${GREEN}${BOLD}${msg}${NORMAL}"
}

# Print colored section header without new line
print_wait() {
  local msg="$1"
  echo -en "${YELLOW}${BOLD}${msg}${NORMAL}"
}

# Print empty line
print_newline() {
  echo ""
}

print_error() {
  local msg="$1"
  echo -e "${RED}${BOLD}${msg}${NORMAL}"
}

# Run bun command in a directory
run_bun() {
  local dir="$1"
  shift
  print_header "Running bun command in ${dir}..."
  cd "$dir" && bun "$@"
}

# Run bun script in a project
run_bun_script() {
  local project="$1"
  local script="$2"
  print_header "Running ${script}..."
  bun run --filter "${project}" "${script}"
}

# Build a project using turbo
build_project() {
  local filter="$1"
  print_header "Building ${filter}..."
  turbo build --filter="${filter}"
}

# Build a project using turbo
build_project_force() {
  local filter="$1"
  print_header "Building ${filter}..."
  turbo build --filter="${filter}" --force
}
